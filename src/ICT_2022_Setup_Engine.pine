//@version=6
indicator("ICT 2022 — Flow X | HTF Persistent Bias", overlay=true, max_labels_count=500, max_lines_count=500, max_boxes_count=300)

//━━━━━━━━━━━━━━━━━━━
// INPUTS
//━━━━━━━━━━━━━━━━━━━

string GRP_TF    = "🔍 Temporalidades"
string GRP_TRADE = "🎯 Trade Config"
string GRP_OB    = "🧱 Order Block"

htf_tf     = input.timeframe("60", "HTF Orderflow TF (1H/4H)", group=GRP_TF)
mid_tf     = input.timeframe("15", "Sweep TF (15m)",           group=GRP_TF)
use_macros = input.bool(true, "Solo en Macros ICT",            group=GRP_TRADE)
rr_target  = input.float(3.0, "RR Target", minval=1.0, step=0.5, group=GRP_TRADE)
ob_bars    = input.int(10, "Lookback OB (barras)", minval=3, maxval=30, group=GRP_OB)
min_sl_pts = input.float(20.0, "SL mínimo (puntos)", minval=5.0,  group=GRP_TRADE)
max_sl_pts = input.float(50.0, "SL máximo (puntos)", minval=10.0, group=GRP_TRADE)

//━━━━━━━━━━━━━━━━━━━
// OBJECT CLEANUP
//━━━━━━━━━━━━━━━━━━━

var int   MAX_OB_BOXES     = 20
var int   MAX_ENTRY_LABELS = 30
var int   MAX_ENTRY_LINES  = 30
var box[]   obBoxArr       = array.new_box()
var label[] entryLblArr    = array.new_label()
var line[]  entryLineArr   = array.new_line()

obj_cleanBoxes(boxes, maxCount) =>
    while array.size(boxes) > maxCount
        box.delete(array.shift(boxes))

obj_cleanLabels(labels, maxCount) =>
    while array.size(labels) > maxCount
        label.delete(array.shift(labels))

obj_cleanLines(lines, maxCount) =>
    while array.size(lines) > maxCount
        line.delete(array.shift(lines))

//━━━━━━━━━━━━━━━━━━━
// TIME (NY)
//━━━━━━━━━━━━━━━━━━━

ny_hour   = hour(time, "America/New_York")
ny_minute = minute(time, "America/New_York")
ny_time   = ny_hour * 100 + ny_minute

in_macro =
     (ny_time >= 200  and ny_time <= 500)  or
     (ny_time >= 830  and ny_time <= 1100) or
     (ny_time >= 1300 and ny_time <= 1600)

valid_time = use_macros ? in_macro : true

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BLOQUE 1 — HTF BIAS PERSISTENTE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

htf_close = request.security(syminfo.tickerid, htf_tf, close)
htf_open  = request.security(syminfo.tickerid, htf_tf, open)
htf_high  = request.security(syminfo.tickerid, htf_tf, high)
htf_low   = request.security(syminfo.tickerid, htf_tf, low)

htf_bear_fvg_active = request.security(syminfo.tickerid, htf_tf, high < low[2])
htf_bull_fvg_active = request.security(syminfo.tickerid, htf_tf, low  > high[2])
htf_bear_fvg_top    = request.security(syminfo.tickerid, htf_tf, low[2])
htf_bear_fvg_bot    = request.security(syminfo.tickerid, htf_tf, high)
htf_bull_fvg_top    = request.security(syminfo.tickerid, htf_tf, low)
htf_bull_fvg_bot    = request.security(syminfo.tickerid, htf_tf, high[2])

var int   htf_bias       = 0
var float htf_bias_level = na

htf_bear_reaction = htf_bear_fvg_active and htf_close < htf_bear_fvg_bot
htf_bull_reaction = htf_bull_fvg_active and htf_close > htf_bull_fvg_top

htf_bear_invalidated = htf_bias == -1 and not na(htf_bias_level) and htf_close > htf_bias_level
htf_bull_invalidated = htf_bias ==  1 and not na(htf_bias_level) and htf_close < htf_bias_level

if htf_bear_reaction and htf_bias != -1
    htf_bias       := -1
    htf_bias_level := htf_bear_fvg_top

if htf_bull_reaction and htf_bias != 1
    htf_bias       := 1
    htf_bias_level := htf_bull_fvg_bot

if htf_bear_invalidated or htf_bull_invalidated
    htf_bias       := 0
    htf_bias_level := na

bull_bias = htf_bias ==  1
bear_bias = htf_bias == -1

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BLOQUE 2 — 15m SWEEP PERSISTENTE
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

mid_ph    = request.security(syminfo.tickerid, mid_tf, ta.pivothigh(high, 5, 5))
mid_pl    = request.security(syminfo.tickerid, mid_tf, ta.pivotlow(low,   5, 5))
mid_high  = request.security(syminfo.tickerid, mid_tf, high)
mid_low   = request.security(syminfo.tickerid, mid_tf, low)
mid_close = request.security(syminfo.tickerid, mid_tf, close)

var float mid_swing_high = na
var float mid_swing_low  = na

if not na(mid_ph)
    mid_swing_high := mid_ph
if not na(mid_pl)
    mid_swing_low  := mid_pl

mid_sweep_bear_raw = not na(mid_swing_high) and mid_high > mid_swing_high and mid_close < mid_swing_high
mid_sweep_bull_raw = not na(mid_swing_low)  and mid_low  < mid_swing_low  and mid_close > mid_swing_low

var bool  mid_sweep_bear     = false
var bool  mid_sweep_bull     = false
var float mid_sweep_bear_inv = na
var float mid_sweep_bull_inv = na

if mid_sweep_bear_raw and bear_bias
    mid_sweep_bear     := true
    mid_sweep_bear_inv := mid_swing_high

if mid_sweep_bull_raw and bull_bias
    mid_sweep_bull     := true
    mid_sweep_bull_inv := mid_swing_low

if mid_sweep_bear and not na(mid_sweep_bear_inv) and mid_close > mid_sweep_bear_inv
    mid_sweep_bear     := false
    mid_sweep_bear_inv := na

if mid_sweep_bull and not na(mid_sweep_bull_inv) and mid_close < mid_sweep_bull_inv
    mid_sweep_bull     := false
    mid_sweep_bull_inv := na

if not bear_bias
    mid_sweep_bear := false
if not bull_bias
    mid_sweep_bull := false

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BLOQUE 3 — OB REAL (last up/down close antes del impulso)
// Se detecta EN el impulso de desplazamiento,
// mirando hacia atrás para encontrar la última
// vela contraria = el Order Block verdadero
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

body     = math.abs(close - open)
avg_body = ta.sma(body, 20)

// Impulso bajista real: vela grande roja que rompe low previo
bear_impulse = close < open and body > avg_body * 1.5 and close < low[1] and mid_sweep_bear
// Impulso alcista real
bull_impulse = close > open and body > avg_body * 1.5 and close > high[1] and mid_sweep_bull

// Cuando hay impulso, buscar el OB: última vela ALCISTA antes del impulso (bear OB)
// o última vela BAJISTA antes del impulso (bull OB)
var float bear_ob_top    = na
var float bear_ob_bot    = na
var int   bear_ob_bar    = 0
var float bull_ob_top    = na
var float bull_ob_bot    = na
var int   bull_ob_bar    = 0

// FVG del impulso (el gap que deja la vela de desplazamiento)
var float bear_fvg_top = na
var float bear_fvg_bot = na
var float bull_fvg_top = na
var float bull_fvg_bot = na

if bear_impulse and not bear_impulse[1]
    // Buscar última vela verde antes del impulso = Bear OB
    for i = 1 to ob_bars
        if close[i] > open[i]
            bear_ob_top := high[i]   // techo del OB = high de la vela alcista
            bear_ob_bot := low[i]    // piso del OB = low de la vela (rango completo ICT)
            bear_ob_bar := bar_index - i
            break
    // FVG bajista: gap hacia abajo → low de vela previa > high de vela actual
    if low[1] > high
        bear_fvg_top := low[1]
        bear_fvg_bot := high
    else
        bear_fvg_top := na
        bear_fvg_bot := na

if bull_impulse and not bull_impulse[1]
    for i = 1 to ob_bars
        if close[i] < open[i]
            bull_ob_top := high[i]   // techo del OB = high de la vela (rango completo ICT)
            bull_ob_bot := low[i]    // piso del OB = low de la vela bajista
            bull_ob_bar := bar_index - i
            break
    // FVG alcista: gap hacia arriba → high de vela previa < low de vela actual
    if high[1] < low
        bull_fvg_top := low
        bull_fvg_bot := high[1]
    else
        bull_fvg_top := na
        bull_fvg_bot := na

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// BLOQUE 4 — ENTRY: precio RETROCEDE al OB/FVG
// La señal se da cuando el precio VUELVE a la zona
// del OB o FVG tras el impulso — no en el impulso
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Estado: esperando retroceso
var bool awaiting_short_entry = false
var bool awaiting_long_entry  = false

// Activar espera cuando hay impulso confirmado
if bear_impulse and not bear_impulse[1] and not na(bear_ob_top)
    awaiting_short_entry := true

if bull_impulse and not bull_impulse[1] and not na(bull_ob_top)
    awaiting_long_entry := true

// Precio retrocede al OB bajista (sube de vuelta al OB) → ENTRY SHORT
// Entrada: apertura del OB (bear_ob_top), SL sobre el high del OB
price_in_bear_ob = not na(bear_ob_top) and high >= bear_ob_bot and low <= bear_ob_top
price_in_bull_ob = not na(bull_ob_top) and low  <= bull_ob_top and high >= bull_ob_bot

// Calcular SL y verificar que esté en rango realista para NQ/MNQ
short_entry_price = bear_ob_top                         // entrada en el techo del OB
short_sl_price    = bear_ob_top + (bear_ob_top - bear_ob_bot) * 0.5 + min_sl_pts * 0.25
short_sl_distance = short_sl_price - short_entry_price
short_tp_price    = short_entry_price - short_sl_distance * rr_target

long_entry_price  = bull_ob_bot
long_sl_price     = bull_ob_bot - (bull_ob_top - bull_ob_bot) * 0.5 - min_sl_pts * 0.25
long_sl_distance  = long_entry_price - long_sl_price
long_tp_price     = long_entry_price + long_sl_distance * rr_target

// Validar SL en rango de mercado (NQ: 20-50 pts típico)
sl_short_valid = short_sl_distance >= min_sl_pts * 0.25 and short_sl_distance <= max_sl_pts
sl_long_valid  = long_sl_distance  >= min_sl_pts * 0.25 and long_sl_distance  <= max_sl_pts

// Trigger: precio toca el OB por primera vez después del impulso
trigger_short = awaiting_short_entry and price_in_bear_ob and bear_bias and mid_sweep_bear and valid_time and sl_short_valid
trigger_long  = awaiting_long_entry  and price_in_bull_ob and bull_bias and mid_sweep_bull and valid_time and sl_long_valid

// Una sola señal por setup
var bool short_fired = false
var bool long_fired  = false

if trigger_short and not short_fired
    short_fired          := true
    awaiting_short_entry := false

if trigger_long and not long_fired
    long_fired           := true
    awaiting_long_entry  := false

// Reset cuando sweep se invalida
if not mid_sweep_bear
    awaiting_short_entry := false
    short_fired          := false
    bear_ob_top          := na
    bear_ob_bot          := na

if not mid_sweep_bull
    awaiting_long_entry := false
    long_fired          := false
    bull_ob_top         := na
    bull_ob_bot         := na

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// DIBUJOS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

// Mostrar OB en espera (para ver la zona antes de que el precio llegue)
// Solo cuando hay impulso confirmado y esperando retroceso
plotshape(bear_impulse and not bear_impulse[1], title="Bear Impulse", style=shape.triangledown,
     location=location.abovebar, color=color.new(color.red,20), size=size.tiny)
plotshape(bull_impulse and not bull_impulse[1], title="Bull Impulse", style=shape.triangleup,
     location=location.belowbar, color=color.new(color.lime,20), size=size.tiny)

if bear_impulse and not bear_impulse[1] and not na(bear_ob_top)
    newBox = box.new(bear_ob_bar, bear_ob_top, bar_index + 60, bear_ob_bot,
         bgcolor=color.new(#FFA500, 80), border_color=color.new(#FFA500, 30), border_width=1)
    array.push(obBoxArr, newBox)
    obj_cleanBoxes(obBoxArr, MAX_OB_BOXES)
    newLbl = label.new(bear_ob_bar + 1, bear_ob_top, "OB — esperar retroceso",
         style=label.style_none, textcolor=color.new(#FFA500, 10), size=size.small)
    array.push(entryLblArr, newLbl)
    obj_cleanLabels(entryLblArr, MAX_ENTRY_LABELS)

if bull_impulse and not bull_impulse[1] and not na(bull_ob_top)
    newBox = box.new(bull_ob_bar, bull_ob_top, bar_index + 60, bull_ob_bot,
         bgcolor=color.new(#FFA500, 80), border_color=color.new(#FFA500, 30), border_width=1)
    array.push(obBoxArr, newBox)
    obj_cleanBoxes(obBoxArr, MAX_OB_BOXES)
    newLbl = label.new(bull_ob_bar + 1, bull_ob_bot, "OB — esperar retroceso",
         style=label.style_none, textcolor=color.new(#FFA500, 10), size=size.small)
    array.push(entryLblArr, newLbl)
    obj_cleanLabels(entryLblArr, MAX_ENTRY_LABELS)

// ── Alertas JSON para webhook MCP ──
if trigger_short and not trigger_short[1]
    alert('{"type":"short","symbol":"' + syminfo.ticker + '","entry":' + str.tostring(short_entry_price) + ',"sl":' + str.tostring(short_sl_price) + ',"tp":' + str.tostring(short_tp_price) + ',"sl_distance":' + str.tostring(math.round(short_sl_distance, 2)) + ',"rr":' + str.tostring(rr_target) + ',"checklist":{"bias":"bearish","sweep":true,"ob":true,"ob_zone":"' + str.tostring(bear_ob_bot) + '-' + str.tostring(bear_ob_top) + '","in_macro":' + (valid_time ? 'true' : 'false') + '}}', alert.freq_once_per_bar)

if trigger_long and not trigger_long[1]
    alert('{"type":"long","symbol":"' + syminfo.ticker + '","entry":' + str.tostring(long_entry_price) + ',"sl":' + str.tostring(long_sl_price) + ',"tp":' + str.tostring(long_tp_price) + ',"sl_distance":' + str.tostring(math.round(long_sl_distance, 2)) + ',"rr":' + str.tostring(rr_target) + ',"checklist":{"bias":"bullish","sweep":true,"ob":true,"ob_zone":"' + str.tostring(bull_ob_bot) + '-' + str.tostring(bull_ob_top) + '","in_macro":' + (valid_time ? 'true' : 'false') + '}}', alert.freq_once_per_bar)

if bear_impulse and not bear_impulse[1]
    alert('{"type":"impulse","direction":"bearish","symbol":"' + syminfo.ticker + '","ob_top":' + str.tostring(bear_ob_top) + ',"ob_bot":' + str.tostring(bear_ob_bot) + '}', alert.freq_once_per_bar)

if bull_impulse and not bull_impulse[1]
    alert('{"type":"impulse","direction":"bullish","symbol":"' + syminfo.ticker + '","ob_top":' + str.tostring(bull_ob_top) + ',"ob_bot":' + str.tostring(bull_ob_bot) + '}', alert.freq_once_per_bar)

// Señal de entrada cuando el precio LLEGA al OB
if trigger_short and not trigger_short[1]
    l1 = line.new(bar_index, short_entry_price, bar_index + 60, short_entry_price,
         color=color.new(#FFA500, 0), width=1)
    array.push(entryLineArr, l1)
    lb1 = label.new(bar_index + 55, short_entry_price, "Entry SHORT",
         style=label.style_none, textcolor=color.new(#FFA500, 0), size=size.small)
    array.push(entryLblArr, lb1)

    l2 = line.new(bar_index, short_sl_price, bar_index + 60, short_sl_price,
         color=color.new(color.red, 20), width=1, style=line.style_dashed)
    array.push(entryLineArr, l2)
    lb2 = label.new(bar_index + 55, short_sl_price, "SL  " + str.tostring(math.round(short_sl_distance, 2)) + "pts",
         style=label.style_none, textcolor=color.new(color.red, 20), size=size.small)
    array.push(entryLblArr, lb2)

    l3 = line.new(bar_index, short_tp_price, bar_index + 60, short_tp_price,
         color=color.new(color.lime, 20), width=1, style=line.style_dashed)
    array.push(entryLineArr, l3)
    lb3 = label.new(bar_index + 55, short_tp_price, "TP 1:" + str.tostring(rr_target, "#.#"),
         style=label.style_none, textcolor=color.new(color.lime, 20), size=size.small)
    array.push(entryLblArr, lb3)

    lb4 = label.new(bar_index, short_sl_price,
         "▼ SHORT\n" + str.tostring(math.round(short_sl_distance, 1)) + " pts SL",
         style=label.style_label_down, color=color.new(color.red, 10),
         textcolor=color.white, size=size.normal)
    array.push(entryLblArr, lb4)
    obj_cleanLabels(entryLblArr, MAX_ENTRY_LABELS)
    obj_cleanLines(entryLineArr, MAX_ENTRY_LINES)

if trigger_long and not trigger_long[1]
    l1 = line.new(bar_index, long_entry_price, bar_index + 60, long_entry_price,
         color=color.new(#FFA500, 0), width=1)
    array.push(entryLineArr, l1)
    lb1 = label.new(bar_index + 55, long_entry_price, "Entry LONG",
         style=label.style_none, textcolor=color.new(#FFA500, 0), size=size.small)
    array.push(entryLblArr, lb1)

    l2 = line.new(bar_index, long_sl_price, bar_index + 60, long_sl_price,
         color=color.new(color.red, 20), width=1, style=line.style_dashed)
    array.push(entryLineArr, l2)
    lb2 = label.new(bar_index + 55, long_sl_price, "SL  " + str.tostring(math.round(long_sl_distance, 2)) + "pts",
         style=label.style_none, textcolor=color.new(color.red, 20), size=size.small)
    array.push(entryLblArr, lb2)

    l3 = line.new(bar_index, long_tp_price, bar_index + 60, long_tp_price,
         color=color.new(color.lime, 20), width=1, style=line.style_dashed)
    array.push(entryLineArr, l3)
    lb3 = label.new(bar_index + 55, long_tp_price, "TP 1:" + str.tostring(rr_target, "#.#"),
         style=label.style_none, textcolor=color.new(color.lime, 20), size=size.small)
    array.push(entryLblArr, lb3)

    lb4 = label.new(bar_index, long_sl_price,
         "▲ LONG\n" + str.tostring(math.round(long_sl_distance, 1)) + " pts SL",
         style=label.style_label_up, color=color.new(color.green, 10),
         textcolor=color.white, size=size.normal)
    array.push(entryLblArr, lb4)
    obj_cleanLabels(entryLblArr, MAX_ENTRY_LABELS)
    obj_cleanLines(entryLineArr, MAX_ENTRY_LINES)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// PANEL
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

col_ok  = color.new(color.lime, 0)
col_no  = color.new(color.red,  0)
col_bg0 = color.new(color.black, 70)
col_bg1 = color.new(color.black, 75)

var table panel = table.new(position.top_right, 2, 7,
     bgcolor=color.new(color.black,80), border_width=1, border_color=color.new(color.gray,70))

if barstate.islast
    header_txt = bull_bias ? "Potential Bull" : bear_bias ? "Potential Bear" : "No Bias HTF"
    header_bg  = bull_bias ? color.new(#8ECFC9,10) : bear_bias ? color.new(#D9A0A0,10) : color.new(color.gray,60)

    table.cell(panel, 0, 0, header_txt, text_color=color.black, bgcolor=header_bg, text_size=size.normal)
    table.cell(panel, 1, 0, "", bgcolor=header_bg)

    table.cell(panel, 0, 1, "Trade Window", text_color=color.white, bgcolor=col_bg0)
    table.cell(panel, 1, 1, valid_time ? "✅" : "❌", text_color=valid_time ? col_ok : col_no, bgcolor=col_bg0)

    table.cell(panel, 0, 2, "HTF Reacción", text_color=color.white, bgcolor=col_bg1)
    table.cell(panel, 1, 2, bull_bias or bear_bias ? "✅" : "❌",
         text_color=bull_bias or bear_bias ? col_ok : col_no, bgcolor=col_bg1)

    table.cell(panel, 0, 3, "15m Sweep", text_color=color.white, bgcolor=col_bg0)
    table.cell(panel, 1, 3, mid_sweep_bull or mid_sweep_bear ? "✅" : "❌",
         text_color=mid_sweep_bull or mid_sweep_bear ? col_ok : col_no, bgcolor=col_bg0)

    table.cell(panel, 0, 4, "Impulso + OB", text_color=color.white, bgcolor=col_bg1)
    imp_ok = (bear_impulse and not na(bear_ob_top)) or (bull_impulse and not na(bull_ob_top))
    table.cell(panel, 1, 4, imp_ok ? "✅" : "❌",
         text_color=imp_ok ? col_ok : col_no, bgcolor=col_bg1)

    table.cell(panel, 0, 5, "Esperando OB", text_color=color.white, bgcolor=col_bg0)
    wait_ok = awaiting_short_entry or awaiting_long_entry
    table.cell(panel, 1, 5, wait_ok ? "⏳" : "—",
         text_color=wait_ok ? color.yellow : color.gray, bgcolor=col_bg0)

    ready      = trigger_short or trigger_long
    fired      = short_fired or long_fired
    status_txt = trigger_long  ? "⚡ LONG"  :
                 trigger_short ? "⚡ SHORT" :
                 awaiting_short_entry or awaiting_long_entry ? "⏳ En OB..." :
                 "Awaiting Setup"
    status_bg  = trigger_long  ? color.new(color.green, 60) :
                 trigger_short ? color.new(color.red,   60) :
                 awaiting_short_entry or awaiting_long_entry ? color.new(color.orange, 70) :
                 col_bg0

    table.cell(panel, 0, 6, status_txt,
         text_color=ready ? color.white : color.gray, bgcolor=status_bg, text_size=size.normal)
    table.cell(panel, 1, 6, "", bgcolor=status_bg)

//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// ALERTAS
//━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

alertcondition(trigger_long  and not trigger_long[1],  "ICT LONG  — En OB", "Precio en OB alcista — Entry LONG")
alertcondition(trigger_short and not trigger_short[1], "ICT SHORT — En OB", "Precio en OB bajista — Entry SHORT")
alertcondition(bear_impulse  and not bear_impulse[1],  "ICT Bear Impulso",  "Impulso bajista — esperar retroceso al OB")
alertcondition(bull_impulse  and not bull_impulse[1],  "ICT Bull Impulso",  "Impulso alcista — esperar retroceso al OB")
alertcondition(bull_impulse  and not bull_impulse[1],  "ICT Bull Impulso",  "Impulso alcista — esperar retroceso al OB")